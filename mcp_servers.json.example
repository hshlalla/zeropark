{
  "_comment": "ZEROPARK_MCP_CONFIG가 가리키는 파일. 여기 등록된 MCP 서버의 도구들이 Super Agent의 도구로 자동 노출된다. 사용하려면 mcp_servers.json으로 복사 후 값 수정.",
  "mcpServers": {
    "neo4j": {
      "_comment": "GraphRAG 1차 연동: 그래프(관계형) 질의를 Super Agent 도구로 노출. uvx 필요(pip install uv).",
      "command": "uvx",
      "args": ["mcp-neo4j-cypher"],
      "env": {
        "NEO4J_URI": "bolt://localhost:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "change-me",
        "NEO4J_DATABASE": "neo4j"
      }
    }
  }
}
