# Zeropark configuration — native framework (NO engine service URLs needed).

ZEROPARK_OUTPUT_DIR=artifacts

# LLM (OpenAI-compatible) — for research / slide content / agents
ZEROPARK_LLM__PROVIDER=openai
ZEROPARK_LLM__MODEL=
ZEROPARK_LLM__API_KEY=
ZEROPARK_LLM__BASE_URL=

# LLM provider can also be "anthropic" (Claude). Embeddings still require an
# OpenAI-compatible endpoint for RAG.

# Optional commodity search backend (Brave/Bing/Tavily/...). NOT SearXNG.
ZEROPARK_SEARCH__BASE_URL=
ZEROPARK_SEARCH__API_KEY=

# Super Agent
ZEROPARK_AGENT_MODEL=gpt-4o
ZEROPARK_AGENT_MAX_ITERATIONS=15
# Path to MCP servers config (relative to working dir or absolute)
ZEROPARK_MCP_CONFIG=mcp_servers.json

# Deployment profile — per-client white-labeling & feature switchboard
ZEROPARK_BRANDING__PRODUCT_NAME=Zeropark
ZEROPARK_BRANDING__CLIENT_NAME=
ZEROPARK_BRANDING__PRIMARY_COLOR=#4F46E5
ZEROPARK_BRANDING__LOGO_URL=
# capability on/off per client, e.g. {"browse": false, "super_agent": true}
ZEROPARK_FEATURES={}

# Control plane (fleet management) — set on client deployments we operate
ZEROPARK_CONTROL_PLANE__URL=
ZEROPARK_CONTROL_PLANE__DEPLOYMENT_ID=
ZEROPARK_CONTROL_PLANE__LICENSE_KEY=
ZEROPARK_CONTROL_PLANE__HEARTBEAT_INTERVAL_S=60

# Control plane SERVER (internal infra only — never ship to clients)
#ZEROPARK_CP_ADMIN_TOKEN=<random admin token>
#CONTROL_PLANE_DATABASE_URL=sqlite+aiosqlite:///./controlplane.db

# Security toggles — DEVELOPMENT ONLY, never enable in production:
# allow crawling/browsing private/loopback addresses (disables SSRF guard)
#ZEROPARK_ALLOW_PRIVATE_URLS=1
# allow the in-process python sandbox when Docker is unavailable (RCE risk)
#ZEROPARK_ALLOW_UNSAFE_SANDBOX=1
